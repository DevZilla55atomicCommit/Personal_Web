---
import BaseLayout from '../../layouts/Single.astro';
import ProjectCard from '../../components/ProjectCard.astro';

interface PageProps {
  params: {
    slug: string;
  };
}

export async function getStaticPaths() {
  const projects = await Astro.glob({
    base: '/content/_projects',
    include: '**/index.md',
    depth: 1,
  });

  const paths = projects.map((file) => ({
    params: {
      slug: file.path.replace('/content/_projects/', ''),
    },
    props: {
      project: file,
    },
  }));

  return paths;
}

const { params, project } = Astro.props;
const { slug } = params;
---

<BaseLayout>
  <article class="max-w-4xl mx-auto px-4 py-12">
    <header class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-primary-100 dark:bg-primary-900/30 text-primary-800 dark:text-primary-200">
          Project
        </span>
        <time class="text-sm text-gray-500 dark:text-gray-500">
          {project.data.date ? new Date(project.data.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          }) : undefined}
        </time>
      </div>

      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-gray-100 mb-4">
        {project.data.title || slug.replace(' ', '-').toUpperCase()}
      </h1>

      <p class="text-xl text-gray-600 dark:text-gray-400 leading-relaxed">
        {project.data.description || 'No description provided for this project.'}
      </p>
    </header>

    <hr class="my-12 border-gray-200 dark:border-gray-800" />

    <!-- Project Details -->
    <div class="space-y-8">
      <section>
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-gray-100 mb-4">
          Overview
        </h2>
        <div class="prose prose-lg dark:prose-invert max-w-none">
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            This project was built to demonstrate skills in modern web development and solve
            real-world problems. It showcases my approach to building scalable, maintainable
            applications.
          </p>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            Throughout the development process, I focused on creating a seamless user experience
            while maintaining high performance and accessibility standards.
          </p>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-gray-100 mb-4">
          Features
        </h2>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-600 dark:text-primary-400 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-600 dark:text-gray-400">Clean, semantic HTML5 structure</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-600 dark:text-primary-400 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-600 dark:text-gray-400">Responsive design with Tailwind CSS</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-600 dark:text-primary-400 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-600 dark:text-gray-400">Optimized performance and accessibility</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-600 dark:text-primary-400 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-600 dark:text-gray-400">Well-documented codebase</span>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-gray-100 mb-4">
          Technologies Used
        </h2>
        <div class="flex flex-wrap gap-2">
          {['JavaScript', 'TypeScript', 'React', 'Astro', 'Tailwind CSS', 'MDX'].map((tech) => (
            <span
              key={tech}
              class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300"
            >
              {tech}
            </span>
          ))}
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-gray-100 mb-4">
          Project Links
        </h2>
        <div class="flex flex-wrap gap-4">
          <a
            href={project.data.link || '/#projects'}
            class="btn btn-primary"
          >
            View Live Demo
          </a>
          <a
            href="https://github.com"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-secondary"
          >
            Source Code
          </a>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-gray-100 mb-4">
          Challenges & Learnings
        </h2>
        <div class="prose prose-lg dark:prose-invert max-w-none text-gray-600 dark:text-gray-400">
          <p>
            Building this project taught me valuable lessons about performance optimization,
            accessibility best practices, and creating intuitive user experiences. I learned the
            importance of testing across different devices and browsers to ensure consistent behavior.
          </p>
          <p>
            One of the biggest challenges was balancing feature richness with performance. By
            implementing code splitting and lazy loading, I was able to deliver a fast, responsive
            application without compromising on functionality.
          </p>
        </div>
      </section>
    </div>

    <footer class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-center sm:text-left text-gray-600 dark:text-gray-400">
          This project is open source and available on GitHub.
        </p>
        <a
          href={project.data.link || '/#projects'}
          class="inline-flex items-center text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 transition-colors focus:outline-none focus:underline"
        >
          Check it out →
        </a>
      </div>
    </footer>
  </article>
</BaseLayout>
