---
import Hero from '../components/Hero.astro';
import FeaturedProjects from '../components/FeaturedProjects.astro';
import ProjectsPreview from '../components/ProjectsPreview.astro';

export const metadata = {
  title: 'Home - Dev Portfolio',
  description: 'Welcome to my portfolio. I build accessible, performant web experiences.',
};
---

<!-- Hero Section -->
<section class="relative min-h-[80vh] flex items-center" aria-labelledby="hero-heading">
  <div class="absolute inset-0 hero-pattern" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-gray-50/50 to-white dark:from-gray-950/50 dark:via-gray-900/50 dark:to-gray-950 pointer-events-none"></div>

  <div class="container-custom relative px-4">
    <Hero
      title="Building the future of the web"
      subtitle="I'm a developer passionate about accessible, performant, and elegant web experiences. Explore my projects and see how I bring ideas to life."
      ctaPrimary="View Projects"
      ctaPrimaryLink="#projects"
      ctaSecondary="Read My Story"
      ctaSecondaryLink="/about/"
    />
  </div>
</section>

<!-- Featured Projects Section -->
<section class="py-16 bg-gray-50 dark:bg-gray-900/50" aria-labelledby="featured-heading">
  <div class="container-custom px-4">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <span class="inline-block badge mb-4">Featured Work</span>
      <h2 id="featured-heading" class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4">
        Recent Highlights
      </h2>
      <p class="text-lg text-gray-600 dark:text-gray-400">
        Here are some of my latest projects that showcase my skills and passion.
      </p>
    </div>

    <FeaturedProjects limit={3} />
  </div>
</section>

<!-- Full Projects Section -->
<section id="projects" class="py-16" aria-labelledby="projects-heading">
  <div class="container-custom px-4">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h2 id="projects-heading" class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4">
        All Projects
      </h2>
      <p class="text-lg text-gray-600 dark:text-gray-400">
        Check out all my projects, from personal experiments to production-ready applications.
      </p>
    </div>

    <ProjectsPreview />
  </div>
</section>

<!-- Call to Action -->
<section class="py-16 bg-gradient-to-br from-primary-600 to-primary-800 text-white" aria-labelledby="cta-heading">
  <div class="container-custom px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 id="cta-heading" class="text-3xl md:text-4xl font-bold mb-6">
        Want to work together?
      </h2>
      <p class="text-xl text-primary-100 mb-8">
        I'm always open to new opportunities and interesting projects. Let's build something amazing together.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/contact/"
          class="btn bg-white text-primary-700 hover:bg-primary-50 shadow-lg hover:shadow-xl transition-all duration-200"
        >
          Get in Touch
        </a>
        <a
          href="mailto:devzilla@example.com"
          class="btn glass text-white hover:bg-white/10 backdrop-blur-sm"
        >
          Email Me
        </a>
      </div>
    </div>
  </div>
</section>
