---
import ProjectCard from './ProjectCard.astro';

interface Project {
  title: string;
  description: string;
  tags: string[];
  link: string;
  featured?: boolean;
  featuredRank?: number;
  date: string;
  imageUrl?: string;
}

interface FeaturedProjectsProps {
  limit?: number;
  projects?: Project[];
}

// Featured projects - hardcoded for now (can be extended)
const featuredProjects: Project[] = [
  {
    title: 'Project Alpha',
    description: 'An innovative platform that streamlines workflows and enhances team collaboration through intelligent automation and real-time updates.',
    tags: ['automation', 'collaboration', 'real-time'],
    link: '/projects/alpha/',
    featured: true,
    featuredRank: 1,
    date: '2026-03-15',
  },
  {
    title: 'Dashboard Beta',
    description: 'A comprehensive analytics dashboard providing actionable insights with beautiful visualizations and customizable widgets.',
    tags: ['analytics', 'dashboard', 'visualization'],
    link: '/projects/dashboard/',
    featured: true,
    featuredRank: 2,
    date: '2026-02-28',
  },
  {
    title: 'API Gateway',
    description: 'High-performance API gateway with rate limiting, authentication, and comprehensive monitoring for enterprise applications.',
    tags: ['api', 'security', 'monitoring'],
    link: '/projects/api/',
    featured: true,
    featuredRank: 3,
    date: '2026-01-20',
  },
];

// Use passed projects if provided, otherwise use hardcoded ones
if (Astro.props.projects) {
  featuredProjects.splice(0, featuredProjects.length, ...Astro.props.projects.slice(0, Astro.props.limit ?? 3));
}
---

<section aria-labelledby="featured-heading">
  <div class="grid gap-8" role="list">
    {featuredProjects.map((project, index) => (
      <div
        role="listitem"
        aria-labelledby={`project-${index}-title`}
        class="group relative overflow-hidden rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 shadow-soft hover:shadow-medium transition-all duration-300 hover:-translate-y-1"
      >
        {/* Featured badge */}
        {project.featured && (
          <div class="absolute top-4 right-4 z-10">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-gradient-to-r from-primary-500 to-accent-500 text-white shadow-lg">
              <svg class="w-4 h-4 mr-1.5" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M10 12a2 2 0 100-4 2 2 0 000 4zm1-8a1 1 0 012 0v2a1 1 0 01-2 0V4zm-4 0a1 1 0 00-2 0v2a1 1 0 002 0V4zm4 0a1 1 0 002 0V4a1 1 0 00-2 0v2zM4 6a1 1 0 00-1 1v2a1 1 0 001 1h.7a1.7 1.7 0 003.4 0H4zm13 0h-2a1 1 0 00-1-1V7a1 1 0 001-1h2V6zM8 6a1 1 0 00-1 1v2a1 1 0 001 1h2a1 1 0 001-1V7a1 1 0 00-1-1H8z"
                  clip-rule="evenodd"
                />
              </svg>
              Featured
            </span>
          </div>
        )}

        <div class="p-6">
          <div class="flex items-start justify-between mb-4">
            <div class="flex-1">
              <h3 id={`project-${index}-title`} class="text-xl font-bold text-gray-900 dark:text-gray-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                {project.title}
              </h3>
              <p class="mt-2 text-gray-600 dark:text-gray-400 leading-relaxed">
                {project.description}
              </p>
            </div>
            {project.imageUrl && (
              <img
                src={project.imageUrl}
                alt={`Thumbnail for ${project.title}`}
                class="w-20 h-20 rounded-xl object-cover border border-gray-200 dark:border-gray-700 group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
                width="80"
                height="80"
              />
            )}
          </div>

          <div class="flex flex-wrap gap-2 mb-4">
            {project.tags.slice(0, 3).map((tag) => (
              <span
                key={tag}
                class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 group-hover:bg-primary-100 dark:group-hover:bg-primary-900/30 group-hover:text-primary-700 dark:group-hover:text-primary-300 transition-colors"
              >
                {tag}
              </span>
            ))}
          </div>

          <div class="flex items-center justify-between pt-4 border-t border-gray-100 dark:border-gray-800">
            <span class="text-xs text-gray-500 dark:text-gray-500">
              {new Date(project.date).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </span>
            <a
              href={project.link}
              class="inline-flex items-center text-sm font-medium text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 transition-colors focus:outline-none focus:underline"
            >
              View Project
              <svg class="ml-1.5 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"
                />
              </svg>
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>

  {featuredProjects.length === 0 && (
    <div class="text-center py-12">
      <p class="text-gray-500 dark:text-gray-400">
        No featured projects found. Check the <code class="text-sm">content/_projects</code> directory.
      </p>
    </div>
  )}
</section>
