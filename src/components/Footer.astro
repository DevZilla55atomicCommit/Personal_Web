---
import SocialLink from './SocialLink.astro';

const socialLinks = [
  { label: 'GitHub', href: '/github', external: false },
  { label: 'Twitter', href: '/twitter', external: false },
  { label: 'LinkedIn', href: '/linkedin', external: false },
  { label: 'CodePen', href: '/codepen', external: false },
];
---

<footer
  class="border-t border-gray-200 dark:border-gray-800 bg-gray-50/50 dark:bg-gray-950/50"
  role="contentinfo"
  aria-label="Footer"
>
  <div class="container-custom px-4 py-12">
    <div class="grid md:grid-cols-3 gap-8 mb-8">
      <!-- Brand -->
      <div>
        <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4">
          {config?.siteTitle || 'Dev Portfolio'}
        </h3>
        <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
          Building accessible, performant, and elegant web experiences. Let's create something amazing together.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-4">
          Navigation
        </h4>
        <ul class="space-y-2">
          <li>
            <a href="/" class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
              Home
            </a>
          </li>
          <li>
            <a href="/projects/" class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
              Projects
            </a>
          </li>
          <li>
            <a href="/about/" class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
              About
            </a>
          </li>
          <li>
            <a href="/contact/" class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
              Contact
            </a>
          </li>
        </ul>
      </div>

      <!-- Social Links -->
      <div>
        <h4 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-4">
          Connect With Me
        </h4>
        <div class="flex items-center space-x-2">
          {socialLinks.map((social) => (
            <SocialLink
              key={social.label}
              href={social.href}
              label={social.label}
              external={social.external}
            />
          ))}
        </div>
      </div>
    </div>

    <div class="pt-8 border-t border-gray-200 dark:border-gray-800">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-sm text-gray-600 dark:text-gray-400 text-center md:text-left">
          &copy; {new Date().getFullYear()} Dev Portfolio. All rights reserved.
        </p>
        <div class="flex items-center gap-4">
          <a
            href="/"
            class="inline-flex items-center text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors focus:outline-none focus:underline"
          >
            Back to top
          </a>
          <span class="text-sm text-gray-400 dark:text-gray-500">&bull;</span>
          <span class="inline-flex items-center text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
            Built with care
            <svg class="ml-1.5 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
          </span>
        </div>
      </div>
    </div>
  </div>
</footer>
